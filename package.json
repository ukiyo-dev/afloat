{
  "name": "afloat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:caldav:reset": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config scripts/reset-caldav-test-account.mjs",
    "dev:caldav:seed": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config scripts/seed-caldav-test-events.mjs",
    "dev:caldav:sync": "curl -sS -X POST http://localhost:3000/api/sync/recent",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "ical.js": "^2.2.1",
    "next": "16.2.5",
    "postgres": "^3.4.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.1"
}
